
// change me! 
BASEDIR = '/home/grace/work/PPCGG_GeneSetPipeline'

params {

    // Basic settings
    basedir     = BASEDIR
    run_id      = 'combi' // change me! 
                            // important so you can keep track of different output results
                            // when altering settings in this file. all pipeline settings are logged 
                            // in the outputs/<run_id>/pipeline_info/settings.txt file 
                            // for each execution for later reference. 
    // samplesheet = "${BASEDIR}/samplesheet.mutational_processes.tsv"
    samplesheet = "${BASEDIR}/samplesheet.combimets.tsv"
    outputs_dir = "${BASEDIR}/outputs" // please don't change this
    combimets = true    // only should be true for combimets. 

    // Supporting data paths
    sizes            = "${BASEDIR}/data/supporting/refseq/gene_sizes.tsv"
    genesets         = "${BASEDIR}/data/genesets/c5.go.bp.v2024.1.Hs.symbols.tsv"
    hgnc_path        = "${BASEDIR}/data/supporting/hgnc/hgnc_complete_set.txt"
    refseq_gff_path  = "${BASEDIR}/data/supporting/refseq/GRCh37.gff"
    ensembl_gtf_path = "${BASEDIR}/data/supporting/ensembl/GRCh37.tsv"

    // Python script paths used in pipeline
    scripts {
        extract_structvars  = "${BASEDIR}/templates/extract_structvars.py"
        extract_seqvars     = "${BASEDIR}/templates/extract_seqvars.py"
        extract_cna         = "${BASEDIR}/templates/extract_cna.py"
        merge_variants          = "${BASEDIR}/templates/merge_variants.py"
        filter_variants_generic = "${BASEDIR}/templates/filter_variants_generic.py"
        filter_variants_combimets = "${BASEDIR}/templates/filter_variants_combimets.py"
        harmonise_data        = "${BASEDIR}/templates/harmonise_data.py"
        split_mutations       = "${BASEDIR}/templates/split_mutations.py"
        select_genesets       = "${BASEDIR}/templates/select_genesets.py"
        differential_mutation = "${BASEDIR}/templates/differential_mutation.py"
        background_enrichment = "${BASEDIR}/templates/background_enrichment.py"
        summarise_results     = "${BASEDIR}/templates/summarise_results.py"
    }

    // SNV|INDEL variant extraction
    seqvars {
        allow_utr             = true  // include 3' & 5' UTR variants
        allow_splice          = true  // include splicing variants 
        allow_noncoding       = false // include noncoding variants 
        allow_intergenic_dist = 100     // include upsteam/downstream variants within <dist> of gene.
    }
    
    // CNA variant extraction
    cnavars {
        min_span          = 0.99  // minimum proportion of gene intersecting with CNA region. 
        allow_subclonal   = true  // include segments where two states are observed (subclonal).
        allow_amp         = false // include amplifications. 
                                  // see AmpValidator in extract_cna.py for decision logic. 
        allow_deep_del    = true  // include deep deletions. 
                                  // see DeepDelValidator in extract_cna.py for decision logic. 
        allow_shallow_del = false // include shallow deletions. 
                                  // see ShallowDelValidator in extract_cna.py for decision logic. 
        allow_noncoding   = false // include noncoding genes.
        allow_chrX        = false // include variants in chromosome X. chromosome Y not available. 
    }

    // Selecting genesets for downstream analysis
    select_genesets {
        min_genes           = 7    // minimum number of genes in geneset
        max_genes           = 30   // maximum number of genes in geneset
        min_genes_hitprop   = 0.20 // minimum proportion of genes with mutation in geneset.
        min_cohort_hitprop  = 0.20 // minimum proportion of donors (positive cohort) with mutation in geneset.
        max_gene_reliance   = 0.50 // the maximum reliance on a single gene in the geneset.
                                   // eg. 0.5 would remove genesets where a single gene accounts 
                                   // for 50% of all donor hits. 
    }

    // Calculating mutation enrichment above background (pure chance)
    background_enrichment {
        budget = 10 // number of bootstrap samples to use.
    }

    // Combining results from differential cohort & background enrichment analysis
    summarise_results {
        max_plots = 10 // number of oncoprints to create
                       // eg 10 will create oncoprints for the top 10 most significant genesets. 
    }


}